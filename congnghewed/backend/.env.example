# Server config
PORT=3000
NODE_ENV=development
TRUST_PROXY=0
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# Google Sign-In
# Set this to your OAuth 2.0 Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=

# Frontend origin allowlist for local development
# FRONTEND_ORIGIN=http://localhost:5173
# FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5500

# n8n webhook for order notifications
N8N_NOTIFICATION_WEBHOOK_URL=
N8N_NOTIFICATION_WEBHOOK_SECRET=

# Session lifetime in days
SESSION_DAYS=7

# Admin bootstrap account
ADMIN_EMAIL=admin@gifterbakery.com
# Bắt buộc đặt mật khẩu mạnh khi chạy production
ADMIN_PASSWORD=12345
